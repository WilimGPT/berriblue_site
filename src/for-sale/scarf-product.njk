---
layout: layouts/base.njk
title: Product | BerriBlue
pagination:
  data: scarvesForSale
  size: 1
  resolve: keys
  alias: productKey
permalink: "/scarves/{{ productKey | lower }}/"
---

{% block head %}
<style>
  .product-back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
  }
  .product-back-link:hover { color: #222; }

  .product-page {
    display: grid;
    grid-template-columns: 58fr 42fr;
    gap: 4rem;
    align-items: start;
    margin-top: 0.5rem;
  }

  .product-gallery__main {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #f8f8f8;
    overflow: hidden;
    position: relative;
  }

  .product-gallery__main-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    cursor: zoom-in;
  }

  .product-gallery__thumbs {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .product-gallery__thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    object-position: center;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.15s;
    background: #f0f0f0;
    display: block;
  }
  .product-gallery__thumb.is-active,
  .product-gallery__thumb:hover { border-color: #333; }

  .product-info__name {
    font-size: 1.6rem;
    font-weight: 300;
    margin: 0 0 0.75rem;
  }

  .product-info__price {
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 0.4rem;
  }

  .product-info__availability {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 1.5rem;
  }
  .product-info__availability.oos { color: #cc0000; font-weight: 600; }

  .product-info__qty-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  .product-info__qty-row input[type="number"] {
    width: 64px;
    padding: 0.4rem 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.9rem;
    text-align: center;
  }

  .product-info__add-btn {
    display: block;
    width: 100%;
    padding: 0.9rem 1rem;
    background: #5b9bd5;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    cursor: pointer;
    margin-bottom: 2rem;
    transition: background 0.2s;
  }
  .product-info__add-btn:hover:not(:disabled) { background: #4a8ac5; }
  .product-info__add-btn:disabled { background: #b0b0b0; cursor: default; }

  .product-info__details-heading {
    font-size: 0.95rem;
    font-weight: 500;
    margin: 0 0 0.6rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e8e8e8;
  }

  .product-info__details p {
    font-size: 0.9rem;
    color: #555;
    margin: 0.35rem 0;
    line-height: 1.55;
  }

  .go-to-cart-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.85rem;
    font-size: 0.85rem;
    background: #5b9bd5;
    color: #fff;
    border: 1px solid #5b9bd5;
    border-radius: 4px;
    text-decoration: none;
    white-space: nowrap;
  }
  .go-to-cart-btn:hover { background: #4a8ac5; border-color: #4a8ac5; }

  @media (max-width: 840px) {
    .product-page { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
{% endblock %}

{% set product = scarvesForSale[productKey] %}

<div class="section section--white">
  <div class="section-inner">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
      <a href="/scarves/" class="product-back-link" style="margin-bottom:0">&#8592; All scarves</a>
      <a href="/for-sale/checkout/" class="go-to-cart-btn" id="goToCartBtn" style="display:none">Go to Cart</a>
    </div>

    <div class="product-page">

      <div class="product-gallery">
        <div class="product-gallery__main" id="mainImgWrap"></div>
        <div class="product-gallery__thumbs" id="thumbsStrip"></div>
      </div>

      <div class="product-info">
        <h1 class="product-info__name">{{ product.DisplayName }}</h1>
        <div class="product-info__price">{{ product.Price | euroPrice }}</div>
        <div class="product-info__availability" id="availabilityLine">
          <span id="stockCount">{{ product.StockLive }}</span> available
        </div>

        <div class="product-info__qty-row" id="qtyRow">
          <label for="qtyInput">Quantity:</label>
          <input type="number" id="qtyInput" value="1" min="1" max="{{ product.StockLive }}" />
        </div>

        <button class="product-info__add-btn" id="addToBagBtn">Add to Cart</button>

        <div class="product-info__details">
          <h3 class="product-info__details-heading">Product Details</h3>
          {% if product.DisplayMedium %}<p>{{ product.DisplayMedium }}</p>{% endif %}
          {% if product.Width and product.Height %}
            <p>{{ product.Width }} x {{ product.Height }}{% if product.Depth %} x {{ product.Depth }}{% endif %} cm</p>
          {% endif %}
          {% if product.Description %}
            <p style="margin-top:0.6rem">{{ product.Description }}</p>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Added to cart modal -->
<div id="addedModal" style="display:none;position:fixed;inset:0;z-index:500;align-items:center;justify-content:center">
  <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45)" id="addedOverlay"></div>
  <div style="position:relative;background:#fff;border-radius:8px;padding:2rem 2rem 1.5rem;width:340px;max-width:90vw;text-align:center;z-index:1">
    <p style="font-size:1.1rem;font-weight:400;margin:0 0 0.35rem">Added to cart!</p>
    <p id="addedItemName" style="font-size:0.85rem;color:#666;margin:0 0 1.5rem"></p>
    <div style="display:flex;flex-direction:column;gap:0.6rem">
      <a href="/for-sale/checkout/" style="display:block;padding:0.75rem;background:#5b9bd5;color:#fff;border-radius:4px;text-decoration:none;font-size:0.95rem">Go to checkout</a>
      <a href="/scarves/" style="display:block;padding:0.75rem;background:none;border:1px solid #ccc;border-radius:4px;text-decoration:none;font-family:inherit;font-size:0.95rem;color:#333;text-align:center">Continue browsing</a>
    </div>
  </div>
</div>

<!-- Lightbox modal -->
<div class="artwork-modal" id="artwork-modal" hidden>
  <div class="artwork-modal__overlay" id="modal-overlay"></div>
  <button class="artwork-modal__close" id="modal-close" aria-label="Close">&#10005;</button>
  <button class="artwork-modal__btn artwork-modal__btn--prev" id="modal-prev" aria-label="Previous">&#8249;</button>
  <div class="artwork-modal__stage" id="modal-stage"></div>
  <button class="artwork-modal__btn artwork-modal__btn--next" id="modal-next" aria-label="Next">&#8250;</button>
  <div class="artwork-modal__counter" id="modal-counter"></div>
</div>

<script>
localStorage.setItem('bb_last_browse', 'scarves');
const PRODUCT_ID    = {{ productKey | dump | safe }};
const saleThumb     = {{ product.SaleThumb | dump | safe }};
const galleryImages = {{ (product.Gallery if product.Gallery else []) | dump | safe }};
const media         = [saleThumb, ...galleryImages].filter(Boolean);

const mainWrap   = document.getElementById("mainImgWrap");
const thumbStrip = document.getElementById("thumbsStrip");
let currentIndex = 0;

function setMainMedia(url, idx) {
  currentIndex = idx;
  mainWrap.innerHTML = "";
  const img = document.createElement("img");
  img.src = url; img.alt = ""; img.className = "product-gallery__main-media";
  img.draggable = false;
  img.addEventListener("click", () => openModal(idx));
  mainWrap.appendChild(img);
  document.querySelectorAll(".product-gallery__thumb").forEach((t, i) => {
    t.classList.toggle("is-active", i === idx);
  });
}

media.forEach((url, i) => {
  const thumb = document.createElement("img");
  thumb.src = url; thumb.alt = "";
  thumb.className = "product-gallery__thumb" + (i === 0 ? " is-active" : "");
  thumb.draggable = false;
  thumb.addEventListener("click", () => setMainMedia(url, i));
  thumb.addEventListener("contextmenu", e => e.preventDefault());
  thumbStrip.appendChild(thumb);
});

if (media.length > 0) setMainMedia(media[0], 0);
if (media.length <= 1) thumbStrip.hidden = true;

// Lightbox
const modal        = document.getElementById("artwork-modal");
const modalStage   = document.getElementById("modal-stage");
const modalCounter = document.getElementById("modal-counter");
const modalPrev    = document.getElementById("modal-prev");
const modalNext    = document.getElementById("modal-next");
let modalIndex = 0;

function renderModal() {
  modalStage.innerHTML = "";
  const img = document.createElement("img");
  img.src = media[modalIndex]; img.alt = "";
  modalStage.appendChild(img);
  modalCounter.textContent = media.length > 1 ? (modalIndex + 1) + " / " + media.length : "";
}

function openModal(index) {
  modalIndex = index; renderModal();
  modal.hidden = false; document.body.style.overflow = "hidden";
}

function closeModal() {
  modal.hidden = true; modalStage.innerHTML = ""; document.body.style.overflow = "";
}

modalPrev.addEventListener("click", () => { modalIndex = (modalIndex - 1 + media.length) % media.length; renderModal(); });
modalNext.addEventListener("click", () => { modalIndex = (modalIndex + 1) % media.length; renderModal(); });
document.getElementById("modal-close").addEventListener("click", closeModal);
document.getElementById("modal-overlay").addEventListener("click", closeModal);
if (media.length <= 1) { modalPrev.hidden = true; modalNext.hidden = true; }

document.addEventListener("keydown", e => {
  if (modal.hidden) return;
  if (e.key === "Escape") closeModal();
  if (e.key === "ArrowLeft")  { modalIndex = (modalIndex - 1 + media.length) % media.length; renderModal(); }
  if (e.key === "ArrowRight") { modalIndex = (modalIndex + 1) % media.length; renderModal(); }
});

// Cart
const CART_TTL = 7 * 24 * 60 * 60 * 1000;
function readCart() {
  const expires = localStorage.getItem("bb_cart_expires");
  if (expires && Date.now() > Number(expires)) {
    localStorage.removeItem("bb_cart"); localStorage.removeItem("bb_cart_expires"); return [];
  }
  return JSON.parse(localStorage.getItem("bb_cart") || "[]");
}
function writeCart(cart) {
  localStorage.setItem("bb_cart", JSON.stringify(cart));
  localStorage.setItem("bb_cart_expires", Date.now() + CART_TTL);
}

const PRODUCT_DATA = {
  id:          PRODUCT_ID,
  displayName: {{ product.DisplayName | dump | safe }},
  price:       {{ product.Price or 0 }},
  saleThumb:   {{ product.SaleThumb | dump | safe }},
  shipping:    {{ product.Shipping | dump | safe }}
};

const addedModal    = document.getElementById("addedModal");
const addedItemName = document.getElementById("addedItemName");
let liveStock = {{ product.StockLive or 0 }};

function getCartQty() {
  const item = readCart().find(i => i.id === PRODUCT_ID);
  return item ? item.quantity : 0;
}

function refreshStockUI() {
  const effective = liveStock - getCartQty();
  const availEl = document.getElementById("availabilityLine");
  const qtyRow  = document.getElementById("qtyRow");
  const addBtn  = document.getElementById("addToBagBtn");
  const qtyIn   = document.getElementById("qtyInput");

  if (effective <= 0) {
    availEl.innerHTML = "Out of stock";
    availEl.className = "product-info__availability oos";
    qtyRow.hidden = true; addBtn.disabled = true;
  } else {
    availEl.innerHTML = `<span id="stockCount">${effective}</span> available`;
    availEl.className = "product-info__availability";
    qtyRow.hidden = false; addBtn.disabled = false;
    qtyIn.max = effective;
    if (parseInt(qtyIn.value) > effective) qtyIn.value = effective;
  }
}

refreshStockUI();

(function() {
  if (readCart().length) document.getElementById("goToCartBtn").style.display = "";
})();

document.getElementById("addToBagBtn").addEventListener("click", () => {
  const qty = Math.max(1, parseInt(document.getElementById("qtyInput").value) || 1);
  const cart = readCart();
  const existing = cart.find(i => i.id === PRODUCT_DATA.id);
  if (existing) existing.quantity += qty;
  else cart.push({ ...PRODUCT_DATA, quantity: qty });
  writeCart(cart);
  refreshStockUI();
  document.getElementById("goToCartBtn").style.display = "";
  addedItemName.textContent = PRODUCT_DATA.displayName;
  addedModal.style.display = "flex";
});

document.getElementById("addedOverlay").addEventListener("click", () => {
  addedModal.style.display = "none";
});

(async () => {
  try {
    const res = await fetch("https://berriblue-worker.berriblue-stock.workers.dev/stock/" + encodeURIComponent(PRODUCT_ID));
    if (!res.ok) return;
    const { stock_live } = await res.json();
    liveStock = stock_live;
    refreshStockUI();
  } catch (e) { /* keep build-time values */ }
})();
</script>

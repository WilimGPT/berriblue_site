<script>
// Set "Continue browsing" destination based on where the user last came from
(function() {
  const BROWSE_URLS = { scarves: '/scarves/', artworks: '/for-sale/' };
  const last = localStorage.getItem('bb_last_browse');
  const url  = BROWSE_URLS[last] || BROWSE_URLS.artworks;
  document.getElementById('continueBrowsingLink').href = url;
  document.getElementById('emptyCartBrowseLink').href  = url;
})();

const SHIPPING_REGIONS = {{ shippingRegions | dump | safe }};

function fmtPrice(n) {
  return "€" + Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, " ");
}

// --- Cart helpers (1-week expiry) ---
const CART_TTL = 7 * 24 * 60 * 60 * 1000;
function readCart() {
  const expires = localStorage.getItem("bb_cart_expires");
  if (expires && Date.now() > Number(expires)) {
    localStorage.removeItem("bb_cart");
    localStorage.removeItem("bb_cart_expires");
    return [];
  }
  return JSON.parse(localStorage.getItem("bb_cart") || "[]");
}
function writeCart(c) {
  localStorage.setItem("bb_cart", JSON.stringify(c));
  localStorage.setItem("bb_cart_expires", Date.now() + CART_TTL);
}

// --- Load cart ---
let cart = readCart();
let currentShipping = 0;

function saveCart() {
  writeCart(cart);
}

function onCartChanged() {
  saveCart();
  if (!cart.length) {
    document.getElementById("checkoutLayout").style.display = "none";
    document.getElementById("emptyCart").hidden = false;
    return;
  }
  renderCart();
  // Re-run shipping in case available methods changed
  const countryEl = document.getElementById("cfCountry");
  if (countryEl.value) updateShipping();
}

if (!cart.length) {
  document.getElementById("emptyCart").hidden = false;
} else {
  document.getElementById("checkoutLayout").style.display = "grid";
  renderCart();
}

function renderCart() {
  const list = document.getElementById("cartItemsList");
  list.innerHTML = "";
  let subtotal = 0;

  cart.forEach(item => {
    const li = document.createElement("li");
    li.className = "cart-item";

    const img = document.createElement("img");
    img.src = item.saleThumb || "";
    img.alt = item.displayName;
    img.className = "cart-item__thumb";

    const info = document.createElement("div");
    info.className = "cart-item__info";
    info.innerHTML = `<p class="cart-item__name">${item.displayName}</p>
      ${item.option ? `<p class="cart-item__meta">Option: ${item.option}</p>` : ''}
      <p class="cart-item__meta">Qty: ${item.quantity}</p>`;

    const price = document.createElement("span");
    price.className = "cart-item__price";
    price.textContent = fmtPrice(item.price * item.quantity);

    const removeBtn = document.createElement("button");
    removeBtn.textContent = "×";
    removeBtn.title = "Remove";
    removeBtn.style.cssText = "background:none;border:none;font-size:1.2rem;color:#aaa;cursor:pointer;padding:0 0 0 0.75rem;line-height:1;flex-shrink:0";
    removeBtn.addEventListener("click", () => removeItem(item.id));

    li.appendChild(img);
    li.appendChild(info);
    li.appendChild(price);
    li.appendChild(removeBtn);
    list.appendChild(li);

    subtotal += item.price * item.quantity;
  });

  document.getElementById("subtotalDisplay").textContent = fmtPrice(subtotal);
}

function removeItem(id) {
  cart = cart.filter(i => i.id !== id);
  onCartChanged();
}

document.getElementById("clearCartBtn").addEventListener("click", () => {
  cart = [];
  onCartChanged();
});

// --- Shipping ---
document.getElementById("cfCountry").addEventListener("change", updateShipping);

function updateShipping() {
  const code = document.getElementById("cfCountry").value;
  const section = document.getElementById("shippingSection");
  const optionsWrap = document.getElementById("shippingOptions");
  const totalWrap = document.getElementById("orderTotalWrap");

  if (!code) { section.hidden = true; totalWrap.hidden = true; return; }

  const region = SHIPPING_REGIONS[code] || null;
  section.hidden = false;
  optionsWrap.innerHTML = "";
  totalWrap.hidden = true;
  document.getElementById("payBtn").disabled = true;

  if (!region) {
    optionsWrap.innerHTML = `<p class="shipping-unavailable">Standard shipping is not available to your location. Please <a href="mailto:info@berriblue.com">contact me</a> and we can work something out.</p>`;
    return;
  }

  // Find the highest shipping cost, but block entirely if ANY item has no
  // shippable option (null) for this region — one unshippable item blocks all.
  let maxCost = null;
  let maxName = null;
  let blocked = false;

  for (const item of cart) {
    if (!item.shipping) { blocked = true; break; }
    let itemHasOption = false;
    for (const method of Object.values(item.shipping)) {
      const cost = method[region];
      if (cost !== null && cost !== undefined) {
        itemHasOption = true;
        if (maxCost === null || cost > maxCost) {
          maxCost = cost;
          maxName = method.name || null;
        }
      }
    }
    if (!itemHasOption) { blocked = true; break; }
  }

  if (blocked || maxCost === null) {
    optionsWrap.innerHTML = `<p class="shipping-unavailable">Standard shipping is not available to your location. Please <a href="mailto:info@berriblue.com">contact me</a> and we can work something out.</p>`;
    return;
  }

  optionsWrap.innerHTML = `<div style="display:flex;justify-content:space-between;font-size:0.9rem;padding:0.4rem 0 0.1rem">
    <span style="color:#555">Delivery${maxName ? `<br><span style="font-size:0.8rem;color:#aaa">${maxName}</span>` : ""}</span>
    <span style="font-weight:500;align-self:center">${maxCost === 0 ? "Free" : fmtPrice(maxCost)}</span>
  </div>`;

  const subtotal = cart.reduce((s, i) => s + i.price * i.quantity, 0);
  currentShipping = maxCost;
  document.getElementById("orderTotalDisplay").textContent = fmtPrice(subtotal + maxCost);
  totalWrap.hidden = false;
  document.getElementById("payBtn").disabled = false;
  document.getElementById("formErrorMsg").hidden = true;
  document.getElementById("phoneErrorMsg").hidden = true;
}

// --- Form validation ---
function isValidEmail(v) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());
}

const WORKER_URL = "https://berriblue-worker.berriblue-stock.workers.dev";

function getContactFields() {
  return {
    firstName: document.getElementById("cfFirstName").value.trim(),
    lastName:  document.getElementById("cfLastName").value.trim(),
    email:     document.getElementById("cfEmail").value.trim(),
    phone:     document.getElementById("cfPhone").value.trim(),
    addr1:     document.getElementById("cfAddr1").value.trim(),
    addr2:     document.getElementById("cfAddr2").value.trim(),
    city:      document.getElementById("cfCity").value.trim(),
    postcode:  document.getElementById("cfPostcode").value.trim(),
    country:   document.getElementById("cfCountry").value,
  };
}

function validateForm() {
  const f = getContactFields();
  const required = [f.firstName, f.lastName, f.email, f.phone, f.addr1, f.city, f.postcode, f.country];
  const hasFieldError   = required.some(v => !v) || !isValidEmail(f.email);
  const phoneMissing    = !f.phone;
  const privacyAccepted = document.getElementById("privacyCheck").checked;

  document.getElementById("formErrorMsg").hidden    = !hasFieldError;
  document.getElementById("phoneErrorMsg").hidden   = !phoneMissing;
  document.getElementById("privacyErrorMsg").hidden = privacyAccepted;

  return !hasFieldError && privacyAccepted;
}

document.getElementById("payBtn").addEventListener("click", () => {
  if (!validateForm()) return;

  const contact         = getContactFields();
  const marketingConsent = document.getElementById("marketingCheck").checked;
  const payBtn          = document.getElementById("payBtn");
  const paypalContainer = document.getElementById("paypalContainer");
  const errorMsg        = document.getElementById("paymentErrorMsg");

  payBtn.style.display    = "none";
  paypalContainer.style.display = "block";
  errorMsg.hidden         = true;

  paypal.Buttons({
    createOrder: async () => {
      const res = await fetch(`${WORKER_URL}/checkout/create-order`, {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          cart: cart.map(i => ({ id: i.id, quantity: i.quantity, displayName: i.displayName, ...(i.option && { option: i.option }) })),
          country: contact.country,
          contact,
          marketingConsent,
        }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Could not create order");
      return data.orderId;
    },

    onApprove: async (data) => {
      const res = await fetch(`${WORKER_URL}/checkout/capture-order`, {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          orderId: data.orderID,
          cart: cart.map(i => ({ id: i.id, quantity: i.quantity })),
          contact,
          lineItems: cart.map(i => ({ id: i.id, displayName: i.displayName, quantity: i.quantity, price: i.price, ...(i.option && { option: i.option }) })),
          shipping: currentShipping,
        }),
      });
      const result = await res.json();
      if (!res.ok) throw new Error(result.error || "Capture failed");

      localStorage.removeItem("bb_cart");
      localStorage.removeItem("bb_cart_expires");
      window.location.href = "/for-sale/checkout/success/";
    },

    onCancel: () => {
      paypalContainer.style.display = "none";
      payBtn.style.display = "block";
    },

    onError: (err) => {
      paypalContainer.style.display = "none";
      payBtn.style.display = "block";
      errorMsg.textContent = "Payment failed — please try again or contact us.";
      errorMsg.hidden = false;
      console.error("PayPal error:", err);
    },
  }).render("#paypalContainer");
});

// --- Help modal ---
const helpOverlay = document.getElementById("helpModalOverlay");
document.getElementById("needHelpBtn").addEventListener("click", () => {
  helpOverlay.style.display = "flex";
});
document.getElementById("helpModalClose").addEventListener("click", () => {
  helpOverlay.style.display = "none";
  document.getElementById("helpFormWrap").style.display = "";
  document.getElementById("helpSuccessWrap").style.display = "none";
  document.getElementById("helpEmail").value = "";
  document.getElementById("helpEmailError").hidden = true;
  const btn = document.getElementById("helpSubmitBtn");
  btn.disabled = false; btn.textContent = "Contact me";
});
helpOverlay.addEventListener("click", e => {
  if (e.target === helpOverlay) helpOverlay.style.display = "none";
});
document.getElementById("helpSubmitBtn").addEventListener("click", async () => {
  const email = document.getElementById("helpEmail").value.trim();
  const errEl = document.getElementById("helpEmailError");
  if (!isValidEmail(email)) {
    errEl.hidden = false;
    return;
  }
  errEl.hidden = true;

  const btn = document.getElementById("helpSubmitBtn");
  btn.disabled = true; btn.textContent = "Sending…";

  try {
    await fetch(`${WORKER_URL}/checkout/help`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        email,
        cart: cart.map(i => ({ id: i.id, displayName: i.displayName, quantity: i.quantity })),
      }),
    });
    document.getElementById("helpSuccessEmail").textContent = email;
    document.getElementById("helpFormWrap").style.display = "none";
    document.getElementById("helpSuccessWrap").style.display = "";
  } catch (err) {
    btn.disabled = false; btn.textContent = "Contact me";
    alert("Something went wrong. Please email info@berriblue.com directly.");
  }
});
</script>

---
layout: layouts/base.njk
title: Checkout | BerriBlue
permalink: /for-sale/checkout/
---

{% block head %}
<script src="https://www.paypal.com/sdk/js?client-id=AdvfkztczH1sJxws0RyQ61zUi-9zbgJ3yIliY12KWdS6rqA-YIsFqr_-sE-zKlBVjD_hpKQvVbLtVLac&currency=EUR" defer></script>
<style>
  .checkout-back {
    display: inline-block;
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }
  .checkout-back:hover { color: #222; }

  .checkout-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
    margin-top: 0.5rem;
  }

  /* ---- Order summary ---- */
  .checkout-section {
    margin-bottom: 2rem;
  }
  .checkout-section-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #888;
    margin: 0 0 0.9rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #eee;
  }

  .cart-items { list-style: none; margin: 0; padding: 0; }
  .cart-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f0f0f0;
  }
  .cart-item__thumb {
    width: 60px;
    height: 60px;
    object-fit: contain;
    background: #f8f8f8;
    flex-shrink: 0;
  }
  .cart-item__info { flex: 1; min-width: 0; }
  .cart-item__name { font-size: 0.9rem; font-weight: 400; margin: 0 0 0.15rem; }
  .cart-item__meta { font-size: 0.8rem; color: #888; margin: 0; }
  .cart-item__price { font-size: 0.95rem; font-weight: 500; white-space: nowrap; }

  .checkout-subtotal {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    padding: 0.75rem 0 0;
    color: #555;
  }

  /* ---- Form ---- */
  .checkout-form { display: flex; flex-direction: column; gap: 0.75rem; }
  .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }

  .checkout-field { display: flex; flex-direction: column; gap: 0.3rem; }
  .checkout-field label { font-size: 0.8rem; color: #666; }
  .checkout-field input,
  .checkout-field select {
    padding: 0.5rem 0.6rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.9rem;
    background: #fff;
  }
  .checkout-field input:focus,
  .checkout-field select:focus {
    outline: none;
    border-color: #5b9bd5;
  }

  /* ---- Right panel ---- */
  .checkout-panel {
    position: sticky;
    top: 2rem;
  }

  .shipping-unavailable {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.5;
    padding: 0.5rem 0;
  }
  .shipping-unavailable a { color: #5b9bd5; }

  .order-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 1rem;
    font-weight: 500;
    padding: 0.75rem 0;
    border-top: 1px solid #eee;
    margin-top: 0.5rem;
  }

  .checkout-pay-btn {
    display: block;
    width: 100%;
    padding: 0.9rem;
    background: #5b9bd5;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    cursor: pointer;
    margin-top: 1rem;
    transition: background 0.2s;
  }
  .checkout-pay-btn:hover:not(:disabled) { background: #4a8ac5; }
  .checkout-pay-btn:disabled { background: #b0b0b0; cursor: default; }

  .empty-cart {
    text-align: center;
    padding: 4rem 0;
    color: #888;
  }
  .empty-cart a { color: #5b9bd5; text-decoration: none; }

  .form-error {
    font-size: 0.8rem;
    color: #cc0000;
    margin: 0.4rem 0 0;
    line-height: 1.4;
  }

  .help-link {
    display: block;
    width: 100%;
    text-align: right;
    font-size: 0.8rem;
    color: #aaa;
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
    padding: 0.75rem 0 0;
  }
  .help-link:hover { color: #666; }

  .help-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 600;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .help-modal {
    background: #fff;
    border-radius: 8px;
    padding: 2rem;
    width: 400px;
    max-width: 90vw;
    position: relative;
  }
  .help-modal__title {
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.6rem;
  }
  .help-modal__body {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.55;
    margin: 0 0 1.25rem;
  }
  .help-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.1rem;
    color: #aaa;
    cursor: pointer;
    line-height: 1;
    padding: 0.2rem;
  }
  .help-modal__close:hover { color: #333; }
  .help-modal__email {
    width: 100%;
    padding: 0.5rem 0.6rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.9rem;
    box-sizing: border-box;
    margin-bottom: 0.75rem;
  }
  .help-modal__email:focus { outline: none; border-color: #5b9bd5; }
  .help-modal__submit {
    width: 100%;
    padding: 0.7rem;
    background: #5b9bd5;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .help-modal__submit:hover { background: #4a8ac5; }

  @media (max-width: 860px) {
    .checkout-layout { grid-template-columns: 1fr; }
    .checkout-panel { position: static; }
  }
</style>
{% endblock %}


<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {%- set _seoPage = seo.pages[seoKey] if seoKey else null -%}

    {%- if key and artworks and artworks[key] -%}
      {# Artwork detail page — use artwork-specific values #}
      {%- set _artworkSeo = artworks[key] -%}
      {%- set _seoTitle = "BerriBlue | Work | " + _artworkSeo["Display Name"] -%}
      {%- set _seoDesc = _artworkSeo["Meta Description"] if _artworkSeo["Meta Description"] else seo.site.default_description -%}
      {%- set _ogDesc = _seoDesc -%}
      {%- set _ogImage = _artworkSeo.Media.main | replace("/upload/", "/upload/w_1200,h_630,c_fill,g_center/") if _artworkSeo.Media.main else seo.site.default_og_image -%}
    {%- else -%}
      {# Regular page — use seo.json values #}
      {%- set _seoTitle = _seoPage.title if _seoPage else title -%}
      {%- set _seoDesc = _seoPage.description if (_seoPage and _seoPage.description) else seo.site.default_description -%}
      {%- set _ogDesc = _seoPage.og_description if (_seoPage and _seoPage.og_description) else _seoDesc -%}
      {%- set _ogImageRaw = _seoPage.og_image if (_seoPage and _seoPage.og_image) else seo.site.default_og_image -%}
      {%- set _ogGravity = _seoPage.image_gravity if (_seoPage and _seoPage.image_gravity) else "center" -%}
      {%- set _ogImage = _ogImageRaw | replace("/upload/", "/upload/w_1200,h_630,c_fill,g_" + _ogGravity + "/") -%}
    {%- endif -%}
    {%- set _ogUrl = seo.site.site_url + page.url -%}

    <title>{{ _seoTitle }}</title>
    <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
    crossorigin="anonymous"
    referrerpolicy="no-referrer"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@100;200;300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/BerriBlue_favicon.png">

    <meta name="description" content="{{ _seoDesc }}">
    {% if _seoPage and _seoPage.noindex %}<meta name="robots" content="noindex">{% endif %}

    <meta property="og:type" content="website">
    <meta property="og:site_name" content="BerriBlue">
    <meta property="og:title" content="{{ _seoTitle }}">
    <meta property="og:description" content="{{ _ogDesc }}">
    <meta property="og:url" content="{{ _ogUrl }}">
    <meta property="og:image" content="{{ _ogImage }}">

    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="/css/carousel.css">
    {% block head %}{% endblock %}
  </head>
    <body>

        <header class="site-header">
            <div class="site-wrapper">
            {% include "header.njk" %}
            </div>
        </header>

        <main class="site-main">
          {{ content | safe }}
        </main>


        {% include "footer.njk" %}

<script src="/js/carousel.js"></script>
<script src="/js/slideshow.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('img, video').forEach(el => {
      el.addEventListener('contextmenu', e => e.preventDefault());
      el.setAttribute('draggable', 'false');
    });

    // Re-apply to any images injected dynamically (slideshow, modal)
    const observer = new MutationObserver(mutations => {
      mutations.forEach(m => m.addedNodes.forEach(node => {
        if (node.nodeType !== 1) return;
        const els = node.matches('img, video') ? [node] : [...node.querySelectorAll('img, video')];
        els.forEach(el => {
          el.addEventListener('contextmenu', e => e.preventDefault());
          el.setAttribute('draggable', 'false');
          if (el.tagName === 'VIDEO') el.setAttribute('controlsList', 'nodownload');
        });
      }));
    });
    observer.observe(document.body, { childList: true, subtree: true });
  });
</script>

    </body>


</html>




---
layout: layouts/base.njk
seoKey: press
title: Press | BerriBlue
---

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": [
    {% set ns = {"pos": 1, "first": true} %}
    {% for item in press_list %}
      {% if not ns.first %},{% endif %}
      {% set gravity = item.image_gravity if item.image_gravity else "center" %}
      {% set ogImage = item.image | replace("/upload/", "/upload/w_1200,h_630,c_fill,g_" + gravity + "/") %}
      {
        "@type": "ListItem",
        "position": {{ ns.pos }},
        "item": {
          "@type": "Article",
          "headline": {{ item.headline | dump | safe }},
          "datePublished": {{ item.date | dump | safe }},
          "url": {{ item.link | dump | safe }},
          "image": {{ ogImage | dump | safe }},
          "description": {{ item.text | dump | safe }},
          "publisher": {
            "@type": "Organization",
            "name": {{ item.publication | dump | safe }}
          }
        }
      }
      {% set ns = {"pos": ns.pos + 1, "first": false} %}
    {% endfor %}
  ]
}
</script>
{% endblock %}

<div class="section section--white">
  <div class="section-inner">

    <p class="press-enquiries">Press Enquiries or Interviews<br>please contact <a href="mailto:info@berriblue.com">info@berriblue.com</a></p>

    <div class="press-grid">
      {% for item in press_list %}
        <div class="press-card">
          {% set displayImage = item.thumb if item.thumb else item.image %}
          {% if item.link %}
            <a href="{{ item.link }}" target="_blank" rel="noopener" class="press-card__image-link">
              <img src="{{ displayImage }}" alt="{{ item.publication }}" class="press-card__image">
            </a>
          {% else %}
            <div class="press-card__image-link press-card__image-link--no-link">
              <img src="{{ displayImage }}" alt="{{ item.publication }}" class="press-card__image">
            </div>
          {% endif %}

          <div class="press-card__body">
            {% if item.link %}
              <a href="{{ item.link }}" target="_blank" rel="noopener" class="press-card__title">{{ item.publication }}</a>
            {% else %}
              <span class="press-card__title press-card__title--no-link">{{ item.publication }}</span>
            {% endif %}
            <p class="press-card__date">{{ item.date }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</div>
